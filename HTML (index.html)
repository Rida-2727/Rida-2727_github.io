<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Portfolio</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Navbar -->
    <header>
        <h2 class="logo">MyPortfolio</h2>
        <nav>
            <a href="#about">About</a>
            <a href="#achievements">Achievements</a>
            <a href="#projects">Projects</a>
            <a href="#certificates">Certificates</a>
            <a href="#contact">Contact</a>
        </nav>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <h1>Hello, I'm <span>Your Name</span></h1>
        <p>A passionate student & future professional</p>
        <button onclick="scrollToSection('contact')">Contact Me</button>
    </section>

    <!-- About -->
    <section id="about">
        <h2>About Me</h2>
        <p>
            I am a student with a strong interest in technology, learning new skills,
            and building creative projects. I aim to grow professionally and contribute
            to meaningful work.
        </p>
    </section>

    <!-- Achievements -->
    <section id="achievements">
        <h2>Achievements</h2>
        <ul>
            <li>🏆 Won School Coding Competition</li>
            <li>📚 Top 5% in Academics</li>
            <li>🎤 Participated in National Science Fair</li>
        </ul>
    </section>

    <!-- Projects -->
    <section id="projects">
        <h2>Projects</h2>
        <div class="card-container">
            <div class="card">
                <h3>Portfolio Website</h3>
                <p>Created a personal portfolio using HTML, CSS, JS.</p>
            </div>
            <div class="card">
                <h3>Weather App</h3>
                <p>Built using API to fetch live weather data.</p>
            </div>
        </div>
    </section>

    <!-- Certificates -->
    <section id="certificates">
        <h2>Certificates</h2>
        <ul>
            <li>✔ Web Development Course</li>
            <li>✔ Python Programming Certification</li>
        </ul>
    </section>

    <!-- Contact -->
    <section id="contact">
        <h2>Contact Me</h2>
        <form onsubmit="return submitForm()">
            <input type="text" placeholder="Your Name" required>
            <input type="email" placeholder="Your Email" required>
            <textarea placeholder="Your Message" required></textarea>
            <button type="submit">Send</button>
        </form>
        <p id="message"></p>
    </section>

    <footer>
        <p>© 2026 Your Name | Student Portfolio</p>
    </footer>

    <script src="script.js"></script>
</body>
</html>
